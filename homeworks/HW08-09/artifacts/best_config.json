{
  "dataset": "EMNIST",
  "seed": 42,
  "model": {
    "input_dim": 784,
    "hidden_dims": [
      256,
      128,
      64
    ],
    "num_classes": 47,
    "activation": "relu",
    "dropout_p": 0.0,
    "use_batchnorm": true
  },
  "training": {
    "optimizer": "Adam",
    "lr": 0.001,
    "momentum": 0,
    "weight_decay": 0,
    "batch_size": 64,
    "epochs": 20
  }
}